<!-- views/events/subevents.ejs -->
<div class="container">

  <!-- Back link -->
  <div style="padding:clamp(18px,2.5vw,30px) 0 0;" data-aos="fade-up">
    <a href="/events/<%= event._id %>" class="btn-details">
      <i class="bi bi-arrow-left"></i> Back to Event
    </a>
  </div>

  <!-- Header -->
  <div class="page-header" data-aos="fade-down">
    <div class="section-label">Registration</div>
    <h1 class="page-title"><%= event.title %></h1>
    <p class="page-subtitle">Select a session below to register</p>
  </div>

  <div style="max-width:700px;margin:0 auto;padding-bottom:clamp(50px,6vw,90px);">

    <% if (!subEvents || subEvents.length === 0) { %>
      <div class="gallery-empty" data-aos="fade-up">
        <div class="gallery-empty-icon">📋</div>
        <p style="color:var(--tx-muted);font-size:1rem;">Registration details will be announced soon.</p>
        <a href="/events/<%= event._id %>" class="btn-details" style="margin-top:16px;">← Back to Event</a>
      </div>

    <% } else { %>

      <% if (groupedSubEvents && groupedSubEvents.length > 0) { %>
        <% groupedSubEvents.forEach(function(group) { %>

          <!-- Day header -->
          <% if (group.day > 0) { %>
            <div style="display:flex;align-items:center;gap:14px;margin:28px 0 16px;" data-aos="fade-up">
              <div style="
                padding:6px 18px;
                background: linear-gradient(135deg,var(--br),var(--br-deep));
                color:#fff;
                border-radius: var(--r-full);
                font-family: var(--font-display);
                font-size:0.85rem;
                font-weight:700;
                letter-spacing:1px;
                white-space:nowrap;
                box-shadow:0 4px 14px rgba(166,124,82,0.28);
              ">
                DAY <%= group.day %>
                <% var firstSub = group.subEvents[0]; %>
                <% if (firstSub && firstSub.eventDate) { %>
                  &nbsp;·&nbsp;<%= new Date(firstSub.eventDate).toLocaleDateString('en-IN',{weekday:'short',day:'numeric',month:'short'}) %>
                <% } %>
              </div>
              <div style="flex:1;height:1px;background:linear-gradient(90deg,var(--border-l),transparent);"></div>
              <span style="font-size:0.75rem;color:var(--tx-muted);font-weight:600;white-space:nowrap;">
                <%= group.subEvents.length %> session<%= group.subEvents.length !== 1 ? 's' : '' %>
              </span>
            </div>
          <% } %>

          <% group.subEvents.forEach(function(sub, i) { %>
            <div class="sub-card" data-aos="fade-up" data-aos-delay="<%= i * 80 %>">

              <!-- ── TOP ROW: title + register button ── -->
              <div class="sub-card-top">
                <div class="sub-card-left">
                  <h3 class="sub-card-title"><%= sub.title %></h3>

                  <!-- Meta pills row -->
                  <div class="sub-meta-row">
                    <% if (sub.startTime || sub.endTime) { %>
                      <span class="sub-pill sub-pill-time">
                        <i class="bi bi-clock"></i>
                        <%= sub.startTime %><% if (sub.endTime) { %>&nbsp;–&nbsp;<%= sub.endTime %><% } %>
                      </span>
                    <% } %>

                    <% if (sub.isGroupEvent) { %>
                      <span class="sub-pill sub-pill-type">
                        <i class="bi bi-people"></i> Team <%= sub.minTeamSize %>–<%= sub.maxTeamSize %>
                      </span>
                    <% } else { %>
                      <span class="sub-pill sub-pill-type">
                        <i class="bi bi-person"></i> Individual
                      </span>
                    <% } %>

                    <% if (sub.maxParticipants) { %>
                      <%
                        var isFull = sub.registrationCount >= sub.maxParticipants;
                        var spotsLeft = sub.maxParticipants - sub.registrationCount;
                      %>
                      <% if (isFull) { %>
                        <span class="sub-pill sub-pill-full">Full</span>
                      <% } else if (spotsLeft <= 10) { %>
                        <span class="sub-pill sub-pill-warn">Only <%= spotsLeft %> left</span>
                      <% } else { %>
                        <span class="sub-pill sub-pill-cap">Max <%= sub.maxParticipants %></span>
                      <% } %>
                    <% } %>

                    <% if (sub.requirePaymentScreenshot) { %>
                      <span class="sub-pill sub-pill-pay"><i class="bi bi-credit-card"></i> Payment req.</span>
                    <% } %>

                    <% if (sub.externalRegistrationLink && sub.externalRegistrationLink.trim() !== '') { %>
                      <span class="sub-pill sub-pill-ext"><i class="bi bi-box-arrow-up-right"></i> Google Form</span>
                    <% } %>
                  </div>
                </div>

                <!-- Register / Full button -->
                <div class="sub-card-action">
                  <% var isFull2 = sub.maxParticipants && sub.registrationCount >= sub.maxParticipants; %>
                  <% if (isFull2) { %>
                    <button disabled class="sub-btn-disabled">Closed</button>
                  <% } else if (sub.externalRegistrationLink && sub.externalRegistrationLink.trim() !== '') { %>
                    <a href="<%= sub.externalRegistrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-register sub-register-btn">
                      Register <i class="bi bi-box-arrow-up-right"></i>
                    </a>
                  <% } else { %>
                    <a href="/register/<%= sub._id %>" class="btn-register sub-register-btn">
                      Register <i class="bi bi-arrow-right"></i>
                    </a>
                  <% } %>
                </div>
              </div>

              <!-- Description -->
              <% if (sub.description) { %>
                <p class="sub-card-desc"><%= sub.description %></p>
              <% } %>

              <!-- Poster (centered, shown only if present) -->
              <% if (sub.posterImage) { %>
                <div class="sub-poster-wrap">
                  <img src="<%= sub.posterImage %>" alt="<%= sub.title %> Poster" class="sub-poster-img">
                </div>
              <% } %>

            </div>
          <% }); %>

        <% }); %>
      <% } %>

    <% } %>

  </div>
</div>

<style>
/* ── Sub-event card ── */
.sub-card {
  background: var(--cream-alt);
  border: 1px solid var(--border-l);
  border-radius: var(--r-lg);
  overflow: hidden;
  margin-bottom: 16px;
  transition: box-shadow 0.24s, transform 0.24s;
}
.sub-card:hover {
  box-shadow: 0 6px 28px rgba(166,124,82,0.13);
  transform: translateY(-2px);
}

/* Top section */
.sub-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  padding: clamp(14px,2vw,20px) clamp(14px,2vw,20px) 10px;
  flex-wrap: wrap;
}
.sub-card-left { flex: 1; min-width: 0; }
.sub-card-title {
  font-family: var(--font-display);
  font-size: clamp(1rem,2vw,1.15rem);
  font-weight: 800;
  color: var(--tx);
  margin: 0 0 10px 0;
  line-height: 1.25;
}
.sub-card-action { flex-shrink: 0; display: flex; align-items: center; }
.sub-register-btn { white-space: nowrap; }
.sub-btn-disabled {
  padding: 9px 20px;
  border-radius: var(--r-full);
  background: rgba(166,124,82,0.08);
  border: 1.5px solid var(--border-l);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--tx-muted);
  cursor: not-allowed;
}

/* Meta pills row */
.sub-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.sub-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: var(--r-full);
  font-size: 0.74rem;
  font-weight: 700;
  white-space: nowrap;
  border: 1px solid transparent;
}
.sub-pill-time { background: rgba(201,168,76,0.10); border-color: rgba(201,168,76,0.26); color: #8a6914; }
.sub-pill-type { background: rgba(166,124,82,0.08); border-color: rgba(166,124,82,0.20); color: var(--br); }
.sub-pill-cap  { background: rgba(166,124,82,0.08); border-color: rgba(166,124,82,0.20); color: var(--br); }
.sub-pill-full { background: rgba(192,57,43,0.09);  border-color: rgba(192,57,43,0.24); color: #c0392b; }
.sub-pill-warn { background: rgba(241,196,15,0.10); border-color: rgba(241,196,15,0.30); color: #b8860b; }
.sub-pill-pay  { background: rgba(39,174,96,0.08);  border-color: rgba(39,174,96,0.22); color: #27ae60; }
.sub-pill-ext  { background: rgba(39,174,96,0.08);  border-color: rgba(39,174,96,0.22); color: #27ae60; }

/* Description */
.sub-card-desc {
  margin: 0 clamp(14px,2vw,20px) 14px;
  font-size: 0.88rem;
  color: var(--tx-muted);
  line-height: 1.65;
}

/* Poster — centred, no left-float */
.sub-poster-wrap {
  display: flex;
  justify-content: center;
  padding: 0 clamp(14px,2vw,20px) clamp(14px,2vw,20px);
}
.sub-poster-img {
  max-width: 340px;
  width: 100%;
  border-radius: var(--r-md);
  border: 1px solid var(--border-l);
  box-shadow: var(--sh-sm);
  display: block;
}

body.dark-mode .sub-card { background: var(--dk-surface); border-color: var(--border-d); }
</style>
