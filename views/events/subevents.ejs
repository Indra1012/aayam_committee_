<!-- views/events/subevents.ejs -->
<div class="container" style="max-width:860px;padding-bottom:80px;">

  <!-- Back link -->
  <div style="padding-top:clamp(18px,2.5vw,30px);" data-aos="fade-up">
    <a href="/events/<%= event._id %>" class="btn-details">
      <i class="bi bi-arrow-left"></i> Back to Event
    </a>
  </div>

  <!-- Header -->
  <div class="page-header" data-aos="fade-down">
    <div class="section-label"><%= event.title %></div>
    <h1 class="page-title">Register for a Session</h1>
    <% if (event.startDate && event.endDate) { %>
      <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;background:rgba(166,124,82,0.08);border:1px solid rgba(166,124,82,0.20);border-radius:var(--r-full);margin-top:10px;">
        <i class="bi bi-calendar3" style="color:var(--br);"></i>
        <span style="font-size:0.85rem;font-weight:600;color:var(--tx-mid);">
          <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
            <%= new Date(event.startDate).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %>
          <% } else { %>
            <%= new Date(event.startDate).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %> →
            <%= new Date(event.endDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
          <% } %>
        </span>
      </div>
    <% } %>
  </div>

  <!-- External event-level link (if set) -->
  <% if (event.registrationLink && event.registrationLink.trim() !== '') { %>
    <div style="display:flex;align-items:center;gap:12px;padding:12px 18px;background:rgba(166,124,82,0.06);border:1px solid rgba(166,124,82,0.20);border-radius:var(--r-md);margin-bottom:22px;flex-wrap:wrap;" data-aos="fade-up">
      <div style="flex:1;font-size:0.85rem;font-weight:600;color:var(--tx-mid);">
        <i class="bi bi-link-45deg" style="color:var(--br);"></i> External registration also available
      </div>
      <a href="<%= event.registrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-details" style="font-size:0.82rem;padding:7px 16px;white-space:nowrap;flex-shrink:0;">
        Open Form <i class="bi bi-box-arrow-up-right"></i>
      </a>
    </div>
  <% } %>

  <!-- No sub-events fallback -->
  <% if (!subEvents || subEvents.length === 0) { %>
    <div class="gallery-empty" data-aos="fade-up">
      <div class="gallery-empty-icon">📅</div>
      <p>No sessions available yet. Check back soon!</p>
    </div>

  <% } else { %>

    <% if (groupedSubEvents && groupedSubEvents.length > 0) { %>
      <% groupedSubEvents.forEach(function(group) { %>

        <!-- Day divider -->
        <% if (group.day > 0) { %>
          <div style="display:flex;align-items:center;gap:12px;margin:28px 0 14px;" data-aos="fade-up">
            <div style="padding:5px 18px;background:linear-gradient(135deg,var(--br),var(--br-deep));color:#fff;border-radius:var(--r-full);font-size:0.78rem;font-weight:700;letter-spacing:1px;white-space:nowrap;">
              DAY <%= group.day %>
              <% var firstSub = group.subEvents[0]; %>
              <% if (firstSub && firstSub.eventDate) { %>
                &nbsp;·&nbsp;<%= new Date(firstSub.eventDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
              <% } %>
            </div>
            <div style="flex:1;height:1px;background:var(--border-l);"></div>
          </div>
        <% } %>

        <!-- Session cards for this day -->
        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:10px;">
          <% group.subEvents.forEach(function(sub, si) { %>
            <%
              var isFull = sub.maxParticipants && sub.registrationCount >= sub.maxParticipants;
              var hasExternal = sub.externalRegistrationLink && sub.externalRegistrationLink.trim() !== '';
            %>

            <div class="sub-reg-card <%= isFull ? 'sub-reg-card-full' : '' %>" data-aos="fade-up" data-aos-delay="<%= Math.min(si * 50, 200) %>">

              <div class="sub-reg-top">
                <div class="sub-reg-left">

                  <!-- Title -->
                  <div class="sub-reg-title">
                    <%= sub.title %>
                    <% if (isFull) { %>
                      <span style="font-size:0.7rem;font-weight:700;background:rgba(192,57,43,0.10);color:#c0392b;padding:2px 8px;border-radius:var(--r-full);margin-left:8px;vertical-align:middle;">FULL</span>
                    <% } %>
                  </div>

                  <!-- Pills -->
                  <div class="show-sub-pills" style="margin-top:8px;">
                    <% if (sub.startTime || sub.endTime) { %>
                      <span class="spill spill-time">
                        <i class="bi bi-clock"></i>
                        <%= sub.startTime %><% if (sub.endTime) { %>&thinsp;–&thinsp;<%= sub.endTime %><% } %>
                      </span>
                    <% } %>
                    <% if (sub.isGroupEvent) { %>
                      <span class="spill spill-type"><i class="bi bi-people"></i> Team&thinsp;<%= sub.minTeamSize %>–<%= sub.maxTeamSize %></span>
                    <% } else { %>
                      <span class="spill spill-type"><i class="bi bi-person"></i> Individual</span>
                    <% } %>
                    <% if (sub.maxParticipants) { %>
                      <span class="spill spill-cap">
                        <i class="bi bi-person-check"></i>&thinsp;<%= sub.registrationCount %>/<%= sub.maxParticipants %> filled
                      </span>
                    <% } %>
                    <% if (sub.requirePaymentScreenshot) { %>
                      <span class="spill spill-pay"><i class="bi bi-credit-card"></i> Payment req.</span>
                    <% } %>
                    <% if (hasExternal) { %>
                      <span class="spill spill-ext"><i class="bi bi-box-arrow-up-right"></i> External Form</span>
                    <% } %>
                  </div>

                  <!-- Description -->
                  <% if (sub.description) { %>
                    <div style="font-size:0.84rem;color:var(--tx-muted);margin-top:10px;line-height:1.6;">
                      <%= sub.description %>
                    </div>
                  <% } %>

                </div>

                <!-- CTA button -->
                <div class="sub-reg-cta">
                  <% if (isFull) { %>
                    <span class="btn-details" style="opacity:0.5;cursor:not-allowed;font-size:0.85rem;padding:9px 18px;">
                      <i class="bi bi-lock"></i> Full
                    </span>
                  <% } else if (hasExternal) { %>
                    <a href="<%= sub.externalRegistrationLink %>" target="_blank" rel="noopener noreferrer"
                       class="btn-register" style="white-space:nowrap;font-size:0.88rem;padding:10px 20px;">
                      Register <i class="bi bi-box-arrow-up-right"></i>
                    </a>
                  <% } else { %>
                    <a href="/register/<%= sub._id %>"
                       class="btn-register" style="white-space:nowrap;font-size:0.88rem;padding:10px 20px;">
                      Register <i class="bi bi-arrow-right"></i>
                    </a>
                  <% } %>
                </div>
              </div>

              <!-- Capacity bar -->
              <% if (sub.maxParticipants) { %>
                <%
                  var pct    = Math.min(100, Math.round((sub.registrationCount / sub.maxParticipants) * 100));
                %>
                <div style="padding:0 clamp(14px,2vw,20px) clamp(12px,1.5vw,16px);">
                  <div style="height:5px;border-radius:5px;background:rgba(166,124,82,0.12);overflow:hidden;">
                    <div style="height:100%;width:<%= pct %>%;border-radius:5px;background:<%= isFull ? 'linear-gradient(90deg,#c0392b,#e74c3c)' : 'linear-gradient(90deg,var(--br),var(--gold))' %>;transition:width 0.5s ease;"></div>
                  </div>
                </div>
              <% } %>

              <!-- Poster (centred below) -->
              <% if (sub.posterImage) { %>
                <div style="display:flex;justify-content:center;padding:0 clamp(14px,2vw,20px) clamp(12px,2vw,18px);border-top:1px solid var(--border-l);padding-top:clamp(12px,2vw,16px);">
                  <img src="<%= sub.posterImage %>" alt="<%= sub.title %> Poster"
                    style="max-width:320px;width:100%;border-radius:var(--r-md);border:1px solid var(--border-l);display:block;">
                </div>
              <% } %>

            </div>
          <% }); %>
        </div>

      <% }); %>
    <% } %>

  <% } %>

</div>


<style>
/* ── Session card ── */
.sub-reg-card {
  background: var(--cream-alt);
  border: 1.5px solid var(--border-l);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: border-color 0.22s, box-shadow 0.22s;
}
.sub-reg-card:hover {
  border-color: var(--br);
  box-shadow: 0 6px 24px rgba(166,124,82,0.12);
}
.sub-reg-card-full {
  opacity: 0.75;
}
.sub-reg-card-full:hover {
  border-color: rgba(192,57,43,0.35);
  box-shadow: 0 4px 14px rgba(192,57,43,0.07);
}

.sub-reg-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: clamp(14px,2vw,20px);
  flex-wrap: wrap;
}
.sub-reg-left { flex: 1; min-width: 0; }
.sub-reg-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(0.98rem,1.8vw,1.1rem);
  color: var(--tx);
  line-height: 1.3;
}
.sub-reg-cta {
  flex-shrink: 0;
  display: flex;
  align-items: flex-start;
}

/* pills (re-use from show.ejs) */
.show-sub-pills { display:flex;flex-wrap:wrap;gap:5px; }
.spill { display:inline-flex;align-items:center;gap:3px;padding:3px 9px;border-radius:var(--r-full);font-size:0.71rem;font-weight:700;white-space:nowrap;border:1px solid transparent; }
.spill-time { background:rgba(201,168,76,0.10);border-color:rgba(201,168,76,0.26);color:#8a6914; }
.spill-type { background:rgba(166,124,82,0.08);border-color:rgba(166,124,82,0.20);color:var(--br); }
.spill-cap  { background:rgba(166,124,82,0.08);border-color:rgba(166,124,82,0.20);color:var(--br); }
.spill-pay  { background:rgba(39,174,96,0.08);border-color:rgba(39,174,96,0.22);color:#27ae60; }
.spill-ext  { background:rgba(39,174,96,0.08);border-color:rgba(39,174,96,0.22);color:#27ae60; }

.gallery-empty { text-align:center;padding:40px 20px;background:rgba(166,124,82,0.04);border:1.5px dashed rgba(166,124,82,0.22);border-radius:var(--r-lg); }
.gallery-empty-icon { font-size:2.5rem;margin-bottom:10px;opacity:0.5; }
.gallery-empty p { color:var(--tx-muted);font-size:0.92rem;margin:0; }

body.dark-mode .sub-reg-card { background:var(--dk-surface);border-color:var(--border-d); }
</style>
