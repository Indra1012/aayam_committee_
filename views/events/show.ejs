<!-- views/events/show.ejs -->
<div class="container my-5">
  <div class="event-detail-content">


    <!-- Banner -->
    <% if (event.bannerImage) { %>
      <div class="event-detail-banner" data-aos="fade-down" style="position:relative;overflow:hidden;border-radius:var(--r-lg);margin-bottom:32px;">
        <img src="<%= event.bannerImage %>" alt="<%= event.title %>" style="width:100%;max-height:420px;object-fit:cover;display:block;">
        <% if (isPast) { %>
          <div style="position:absolute;top:16px;right:16px;">
            <span class="badge-completed" style="font-size:0.8rem;padding:6px 14px;">Completed</span>
          </div>
        <% } %>
        <% if (event.isPublic === false && user && (user.role === 'admin' || user.role === 'superadmin')) { %>
          <div style="position:absolute;top:16px;left:16px;">
            <span style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;border-radius:var(--r-full);background:rgba(0,0,0,0.65);color:#ffd700;font-size:0.72rem;font-weight:700;letter-spacing:1px;border:1px solid rgba(255,215,0,0.35);backdrop-filter:blur(6px);">
              🔒 Private — Admin View
            </span>
          </div>
        <% } %>
      </div>
    <% } %>


    <!-- Admin action bar -->
    <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
      <div class="mb-3 d-flex gap-2 flex-wrap" data-aos="fade-up">
        <a href="/events/edit/<%= event._id %>" class="btn-details">
          <i class="bi bi-pencil-square"></i> Edit Event
        </a>
        <form action="/events/toggle-visibility/<%= event._id %>" method="POST" style="margin:0;">
          <button type="submit" class="<%= event.isPublic === false ? 'btn-register' : 'btn-admin-warn' %>" style="font-size:0.82rem;">
            <%= event.isPublic === false ? '🌐 Make Public' : '🔒 Make Private' %>
          </button>
        </form>
      </div>
    <% } %>


    <!-- Title & meta -->
    <div data-aos="fade-up" data-aos-delay="60" style="margin-bottom:28px;">
      <% if (!event.bannerImage && isPast) { %>
        <span class="badge-completed" style="margin-bottom:10px;display:inline-block;">Completed</span>
      <% } %>
      <h1 style="font-family:var(--font-display);font-size:clamp(2rem,5vw,3.2rem);font-weight:900;color:var(--tx);line-height:1.12;margin-bottom:14px;letter-spacing:-0.5px;">
        <%= event.title %>
      </h1>
      <% if (event.startDate && event.endDate) { %>
        <div style="display:inline-flex;align-items:center;gap:8px;padding:7px 16px;background:rgba(166,124,82,0.08);border:1px solid rgba(166,124,82,0.2);border-radius:var(--r-full);margin-bottom:20px;">
          <i class="bi bi-calendar3" style="color:var(--br);"></i>
          <span style="font-size:0.88rem;font-weight:600;color:var(--tx-mid);">
            <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
              <%= new Date(event.startDate).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %>
            <% } else { %>
              <%= new Date(event.startDate).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %> →
              <%= new Date(event.endDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
            <% } %>
          </span>
        </div>
      <% } %>
      <div class="event-description-body" data-aos="fade-up"><%- event.description %></div>
      <% if (event.about) { %>
        <div style="background:rgba(166,124,82,0.05);border-left:3px solid var(--br);border-radius:0 var(--r-md) var(--r-md) 0;padding:16px 20px;margin-top:18px;max-width:780px;" data-aos="fade-up">
          <div class="event-description-body"><%- event.about %></div>
        </div>
      <% } %>
    </div>


    <%
      var isAdmin = user && (user.role === 'admin' || user.role === 'superadmin');
      var hasSubEvents = subEvents && subEvents.length > 0;
      var hasExternalLink = event.registrationLink && event.registrationLink.trim() !== '';
      var showRegSection = !isPast || isAdmin;
    %>


    <!-- ═══ REGISTRATION ═══ -->
    <% if (showRegSection) { %>
      <% if (hasExternalLink && !hasSubEvents) { %>
        <div class="detail-section" data-aos="fade-up">
          <h2 class="detail-section-title">Registration</h2>
          <div style="background:linear-gradient(135deg,rgba(166,124,82,0.07),rgba(201,168,76,0.04));border:1.5px solid rgba(166,124,82,0.22);border-radius:var(--r-lg);padding:22px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
            <div>
              <div style="font-family:var(--font-display);font-weight:700;font-size:1rem;color:var(--tx);margin-bottom:4px;">
                <i class="bi bi-link-45deg" style="color:var(--br);"></i> Register via External Form
              </div>
              <div style="font-size:0.82rem;color:var(--tx-muted);">Opens in a new tab</div>
            </div>
            <a href="<%= event.registrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-register" style="white-space:nowrap;flex-shrink:0;">
              Register Now <i class="bi bi-box-arrow-up-right"></i>
            </a>
          </div>
        </div>


      <% } else if (hasSubEvents) { %>
        <div class="detail-section" data-aos="fade-up">
          <h2 class="detail-section-title"><%= isPast ? 'Sessions & Registrations' : 'Register for Sessions' %></h2>
          <% if (!isPast && hasExternalLink) { %>
            <div style="display:flex;align-items:center;gap:12px;padding:11px 16px;background:rgba(166,124,82,0.06);border:1px solid rgba(166,124,82,0.18);border-radius:var(--r-md);margin-bottom:16px;flex-wrap:wrap;">
              <div style="flex:1;font-size:0.83rem;font-weight:600;color:var(--tx-mid);"><i class="bi bi-link-45deg" style="color:var(--br);"></i> External registration also available</div>
              <a href="<%= event.registrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-details" style="font-size:0.8rem;padding:6px 14px;white-space:nowrap;flex-shrink:0;">Open Form <i class="bi bi-box-arrow-up-right"></i></a>
            </div>
          <% } %>


          <% if (groupedSubEvents && groupedSubEvents.length > 0) { %>
            <% groupedSubEvents.forEach(function(group) { %>


              <% if (group.day > 0) { %>
                <div style="display:flex;align-items:center;gap:12px;margin:22px 0 12px;" data-aos="fade-up">
                  <div style="padding:4px 16px;background:linear-gradient(135deg,var(--br),var(--br-deep));color:#fff;border-radius:var(--r-full);font-size:0.78rem;font-weight:700;letter-spacing:1px;white-space:nowrap;">
                    DAY <%= group.day %>
                    <% var firstSub = group.subEvents[0]; %>
                    <% if (firstSub && firstSub.eventDate) { %>&nbsp;·&nbsp;<%= new Date(firstSub.eventDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %><% } %>
                  </div>
                  <div style="flex:1;height:1px;background:var(--border-l);"></div>
                </div>
              <% } %>


              <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:8px;">
                <% group.subEvents.forEach(function(sub) { %>


                  <!-- ── Compact sub-event card ── -->
                  <div class="show-sub-card" data-aos="fade-up">


                    <!-- Row 1: title + action buttons -->
                    <div class="show-sub-top">
                      <div class="show-sub-left">
                        <div class="show-sub-title"><%= sub.title %></div>


                        <!-- Meta pills — all on one compact row -->
                        <div class="show-sub-pills">
                          <% if (sub.startTime || sub.endTime) { %>
                            <span class="spill spill-time">
                              <i class="bi bi-clock"></i>
                              <%= sub.startTime %><% if (sub.endTime) { %>&thinsp;–&thinsp;<%= sub.endTime %><% } %>
                            </span>
                          <% } %>


                          <% if (sub.isGroupEvent) { %>
                            <span class="spill spill-type"><i class="bi bi-people"></i> Team&thinsp;<%= sub.minTeamSize %>–<%= sub.maxTeamSize %></span>
                          <% } else { %>
                            <span class="spill spill-type"><i class="bi bi-person"></i> Individual</span>
                          <% } %>


                          <% if (sub.maxParticipants) { %>
                            <span class="spill spill-cap"><i class="bi bi-person-check"></i> Max&thinsp;<%= sub.maxParticipants %></span>
                          <% } %>


                          <% if (sub.requirePaymentScreenshot) { %>
                            <span class="spill spill-pay"><i class="bi bi-credit-card"></i> Payment req.</span>
                          <% } %>


                          <% if (sub.externalRegistrationLink && sub.externalRegistrationLink.trim() !== '') { %>
                            <span class="spill spill-ext"><i class="bi bi-box-arrow-up-right"></i> External Form</span>
                          <% } %>
                        </div>
                      </div>


                      <!-- Action buttons -->
                      <div class="show-sub-actions">
                        <% if (!isPast) { %>
                          <% if (sub.externalRegistrationLink && sub.externalRegistrationLink.trim() !== '') { %>
                            <a href="<%= sub.externalRegistrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-register" style="white-space:nowrap;font-size:0.85rem;padding:8px 16px;">
                              Register <i class="bi bi-box-arrow-up-right"></i>
                            </a>
                          <% } else { %>
                            <a href="/register/<%= sub._id %>" class="btn-register" style="white-space:nowrap;font-size:0.85rem;padding:8px 16px;">
                              Register <i class="bi bi-arrow-right"></i>
                            </a>
                          <% } %>
                        <% } %>
                        <% if (isAdmin) { %>
                          <a href="/admin/subevents/<%= sub._id %>/registrations" class="btn-details" style="font-size:0.78rem;padding:6px 12px;white-space:nowrap;">
                            <i class="bi bi-people"></i> Registrations
                          </a>
                        <% } %>
                      </div>
                    </div>


                    <!-- Description (if any) -->
                    <% if (sub.description) { %>
                      <div class="show-sub-desc"><%= sub.description %></div>
                    <% } %>


                    <!-- Poster centred (only when no QR, or show even with QR — poster always centred) -->
                    <% if (sub.posterImage) { %>
                      <div class="show-sub-poster-wrap">
                        <img src="<%= sub.posterImage %>" alt="<%= sub.title %> Poster" class="show-sub-poster-img">
                      </div>
                    <% } %>


                  </div>


                <% }); %>
              </div>
            <% }); %>
          <% } %>


          <% if (!isPast && subEvents.length > 1) { %>
            <div style="margin-top:18px;">
              <a href="/events/<%= event._id %>/register" class="btn-register">Browse All Sessions <i class="bi bi-arrow-right"></i></a>
            </div>
          <% } %>
        </div>


      <% } else if (!isPast) { %>
        <div data-aos="fade-up" style="margin:0 0 30px;">
          <p style="color:var(--tx-muted);font-size:0.93rem;padding:14px 18px;background:rgba(166,124,82,0.05);border-radius:var(--r-md);border:1px solid var(--border-l);margin:0;">
            <i class="bi bi-clock"></i> Registrations will open soon.
          </p>
        </div>
      <% } %>
    <% } %>


    <!-- ═══════════════════════════════════════════
         SPEAKERS
         (only rendered if images exist OR admin)
    ════════════════════════════════════════════ -->
    <%
      var hasSpeakerImages = event.speakerImages && event.speakerImages.length > 0;
    %>
    <% if (hasSpeakerImages || isAdmin) { %>
      <div class="detail-section" data-aos="fade-up">
        <% if (hasSpeakerImages) { %>
          <h2 class="detail-section-title">Speakers</h2>
        <% } %>

        <% if (hasSpeakerImages) { %>
          <div class="gallery-grid-new">
            <% event.speakerImages.forEach(function(img, i) { %>
              <%
                var hasName    = img.speakerName && img.speakerName.trim() !== '';
                var hasDetail  = img.detail      && img.detail.trim()      !== '';
                var hasCaption = hasName || hasDetail;
              %>
              <div class="gallery-item-new <%= hasCaption ? '' : 'no-caption-card' %>" data-aos="fade-up" data-aos-delay="<%= Math.min(i * 40, 280) %>">
                <div class="gallery-img-wrap">
                  <img
                    src="<%= img.url %>"
                    alt="<%= hasName ? img.speakerName.trim() : ('Speaker ' + (i+1)) %>"
                    class="gallery-img-actual"
                    loading="lazy"
                    onerror="this.parentElement.parentElement.style.display='none'"
                  >
                  <% if (isAdmin) { %>
                    <form action="/events/<%= event._id %>/speakers/<%= img._id %>/delete" method="POST"
                      style="position:absolute;top:7px;right:7px;margin:0;z-index:2;"
                      onsubmit="return confirm('Remove this speaker image?')">
                      <button type="submit" class="gal-del-btn"><i class="bi bi-x-lg"></i></button>
                    </form>
                  <% } %>
                </div>
                <% if (hasCaption) { %>
                  <div class="gallery-caption-below">
                    <% if (hasName) { %><div class="gcap-name"><%= img.speakerName.trim() %></div><% } %>
                    <% if (hasDetail) { %><div class="gcap-detail"><%= img.detail.trim() %></div><% } %>
                  </div>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } %>

        <!-- Admin upload form for speakers -->
        <% if (isAdmin) { %>
          <form action="/events/<%= event._id %>/speakers" method="POST" enctype="multipart/form-data" class="admin-gallery-upload-form mt-4">
            <div class="section-label" style="margin-bottom:16px;"><i class="bi bi-cloud-upload"></i> Upload Speaker Images</div>
            <div class="gallery-upload-fields">
              <div class="gup-field">
                <label class="gup-label">Speaker Name <span style="font-weight:400;color:var(--tx-muted);text-transform:none;letter-spacing:0;">(optional)</span></label>
                <input type="text" name="speakerName" class="form-control-custom" placeholder="e.g. Dr. Raj Mehta">
              </div>
              <div class="gup-field">
                <label class="gup-label">Caption / Detail <span style="font-weight:400;color:var(--tx-muted);text-transform:none;letter-spacing:0;">(optional)</span></label>
                <input type="text" name="detail" class="form-control-custom" placeholder="e.g. Keynote Speaker · AI Workshop">
              </div>
            </div>
            <div class="gup-file-area" onclick="document.getElementById('speakerFileInput').click()">
              <div class="gup-file-icon">🎤</div>
              <div class="gup-file-label">Click to select speaker images</div>
              <div class="gup-file-hint">JPG, PNG, WEBP · Multiple files allowed · Max 30</div>
              <input type="file" id="speakerFileInput" name="speakerImages" multiple accept="image/*"
                style="display:none;" required onchange="showSpeakerFiles(this)">
              <div id="speakerFileNames" style="margin-top:10px;font-size:0.8rem;color:var(--br);font-weight:600;"></div>
            </div>
            <button type="submit" class="btn-register" style="margin-top:14px;">
              <i class="bi bi-cloud-upload"></i> Upload Speaker Images
            </button>
          </form>
        <% } %>
      </div>
    <% } %>


    <!-- ═══════════════════════════════════════════
         GALLERY
         (only rendered if images exist OR admin)
    ════════════════════════════════════════════ -->
    <%
      var hasGalleryImages = event.galleryImages && event.galleryImages.length > 0;
    %>
    <% if (hasGalleryImages || isAdmin) { %>
      <div class="detail-section" data-aos="fade-up">
        <% if (hasGalleryImages) { %>
          <h2 class="detail-section-title">Event Gallery</h2>
        <% } %>

        <% if (hasGalleryImages) { %>
          <div class="gallery-grid-new">
            <% event.galleryImages.forEach(function(img, i) { %>
              <%
                var hasName    = img.speakerName && img.speakerName.trim() !== '';
                var hasDetail  = img.detail      && img.detail.trim()      !== '';
                var hasCaption = hasName || hasDetail;
              %>
              <div class="gallery-item-new <%= hasCaption ? '' : 'no-caption-card' %>" data-aos="fade-up" data-aos-delay="<%= Math.min(i * 40, 280) %>">
                <div class="gallery-img-wrap">
                  <img
                    src="<%= img.url %>"
                    alt="<%= hasName ? img.speakerName.trim() : ('Gallery image ' + (i+1)) %>"
                    class="gallery-img-actual"
                    loading="lazy"
                    onerror="this.parentElement.parentElement.style.display='none'"
                  >
                  <% if (isAdmin) { %>
                    <form action="/events/<%= event._id %>/gallery/<%= img._id %>/delete" method="POST"
                      style="position:absolute;top:7px;right:7px;margin:0;z-index:2;"
                      onsubmit="return confirm('Remove this image?')">
                      <button type="submit" class="gal-del-btn"><i class="bi bi-x-lg"></i></button>
                    </form>
                  <% } %>
                </div>
                <% if (hasCaption) { %>
                  <div class="gallery-caption-below">
                    <% if (hasName) { %><div class="gcap-name"><%= img.speakerName.trim() %></div><% } %>
                    <% if (hasDetail) { %><div class="gcap-detail"><%= img.detail.trim() %></div><% } %>
                  </div>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } else if (isAdmin) { %>
          <div class="gallery-empty">
            <div class="gallery-empty-icon">🖼</div>
            <p>No gallery images yet.</p>
          </div>
        <% } %>

        <% if (isAdmin) { %>
          <form action="/events/<%= event._id %>/gallery" method="POST" enctype="multipart/form-data" class="admin-gallery-upload-form mt-4">
            <div class="section-label" style="margin-bottom:16px;"><i class="bi bi-cloud-upload"></i> Upload Gallery Images</div>
            <div class="gallery-upload-fields">
              <div class="gup-field">
                <label class="gup-label">Event Name <span style="font-weight:400;color:var(--tx-muted);text-transform:none;letter-spacing:0;">(optional)</span></label>
                <input type="text" name="speakerName" class="form-control-custom" placeholder="e.g. Dr. Raj Mehta">
              </div>
              <div class="gup-field">
                <label class="gup-label">Caption / Detail <span style="font-weight:400;color:var(--tx-muted);text-transform:none;letter-spacing:0;">(optional)</span></label>
                <input type="text" name="detail" class="form-control-custom" placeholder="e.g. Day 1 · AI Workshop">
              </div>
            </div>
            <div class="gup-file-area" onclick="document.getElementById('galleryFileInput').click()">
              <div class="gup-file-icon">📷</div>
              <div class="gup-file-label">Click to select images</div>
              <div class="gup-file-hint">JPG, PNG, WEBP · Multiple files allowed · Max 30</div>
              <input type="file" id="galleryFileInput" name="galleryImages" multiple accept="image/*"
                style="display:none;" required onchange="showGalleryFiles(this)">
              <div id="galleryFileNames" style="margin-top:10px;font-size:0.8rem;color:var(--br);font-weight:600;"></div>
            </div>
            <button type="submit" class="btn-register" style="margin-top:14px;">
              <i class="bi bi-cloud-upload"></i> Upload Images
            </button>
          </form>
        <% } %>
      </div>
    <% } %>


    <!-- ═══ CONDUCTED BY ═══ -->
    <div class="detail-section" data-aos="fade-up">
      <h2 class="detail-section-title">Conducted By</h2>
      <% if (event.conductedBy && event.conductedBy.length > 0) { %>
        <% event.conductedBy.forEach(function(person, i) { %>
          <div class="person-item">
            <div>
              <div class="person-name"><%= person.name %></div>
              <div class="person-email"><%= person.email %></div>
            </div>
            <% if (isAdmin) { %>
              <form action="/events/<%= event._id %>/conducted-by/<%= i %>/delete" method="POST" onsubmit="return confirm('Remove this coordinator?')">
                <button type="submit" class="btn-admin-danger" style="padding:5px 12px;font-size:0.8rem;">✕</button>
              </form>
            <% } %>
          </div>
        <% }); %>
      <% } else { %>
        <p style="color:var(--tx-muted);font-size:0.92rem;">Coordinator details will be updated.</p>
      <% } %>
      <% if (isAdmin) { %>
        <form action="/events/<%= event._id %>/conducted-by" method="POST" class="admin-add-form mt-3">
          <div class="row g-2">
            <div class="col-md-5"><input type="text" name="name" class="form-control" placeholder="Coordinator name" required></div>
            <div class="col-md-5"><input type="email" name="email" class="form-control" placeholder="Email address" required></div>
            <div class="col-md-2"><button type="submit" class="btn-register w-100">Add</button></div>
          </div>
        </form>
      <% } %>
    </div>


    <!-- ═══ DOCUMENTS ═══ -->
    <div class="detail-section" data-aos="fade-up">
      <h2 class="detail-section-title">Event Documents</h2>
      <% if (event.documents && event.documents.length > 0) { %>
        <% var visibleDocs = event.documents.filter(function(d){ return d.isPublic || isAdmin; }); %>
        <% if (visibleDocs.length > 0) { %>
          <% event.documents.forEach(function(doc, i) { %>
            <% if (doc.isPublic || isAdmin) { %>
              <div class="person-item">
                <div>
                  <div class="person-name"><%= doc.title %></div>
                  <% if (!doc.isPublic && isAdmin) { %>
                    <span style="font-size:0.72rem;color:#b8860b;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Admin Only</span>
                  <% } %>
                </div>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                  <%
                    /* View: Google Docs Viewer opens full screen in new tab — works for all Cloudinary raw PDFs/Docs */
                    var gdocsView = 'https://docs.google.com/viewer?url=' + encodeURIComponent(doc.file) + '&embedded=false';
                  %>
                  <a href="<%= gdocsView %>" target="_blank" rel="noopener noreferrer"
                     class="btn-details" style="font-size:0.82rem;padding:6px 14px;">
                    👁 View
                  </a>
                  <%
                    /* Download: for Cloudinary raw files, direct URL is correct — browser downloads with right extension */
                  %>
                  <a href="<%= doc.file %>" target="_blank" rel="noopener noreferrer"
                     class="btn-details" style="font-size:0.82rem;padding:6px 14px;">
                    ⬇ Download
                  </a>
                  <% if (isAdmin) { %>
                    <form action="/events/<%= event._id %>/documents/<%= i %>/delete" method="POST" onsubmit="return confirm('Delete this document?')">
                      <button type="submit" class="btn-admin-danger" style="padding:5px 12px;font-size:0.8rem;">✕</button>
                    </form>
                  <% } %>
                </div>
              </div>
            <% } %>
          <% }); %>
        <% } else { %>
          <p style="color:var(--tx-muted);font-size:0.92rem;">No public documents available.</p>
        <% } %>
      <% } else { %>
        <p style="color:var(--tx-muted);font-size:0.92rem;">No documents uploaded yet.</p>
      <% } %>
      <% if (isAdmin) { %>
        <form action="/events/<%= event._id %>/documents" method="POST" enctype="multipart/form-data" class="admin-add-form mt-3">
          <div class="row g-2">
            <div class="col-md-5"><input type="text" name="title" class="form-control" placeholder="Document title" required></div>
            <div class="col-md-4"><input type="file" name="document" class="form-control" required></div>
            <div class="col-md-3">
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="isPublic" id="isPublicDoc">
                <label class="form-check-label" for="isPublicDoc" style="font-size:0.82rem;color:var(--tx-muted);">Public</label>
              </div>
              <button type="submit" class="btn-register w-100">Upload</button>
            </div>
          </div>
        </form>
      <% } %>
    </div>


    <!-- ═══ REVIEWS (past events only) ═══ -->
    <% if (isPast) { %>
      <div class="detail-section" data-aos="fade-up">
        <h2 class="detail-section-title">⭐ Event Reviews</h2>
        <form action="/events/<%= event._id %>/reviews" method="POST" class="admin-add-form mb-4">
          <div class="row g-2">
            <div class="col-md-4"><input type="text" name="name" class="form-control" placeholder="Your name" required></div>
            <div class="col-md-6"><textarea name="message" class="form-control" placeholder="Write your review..." rows="2" required></textarea></div>
            <div class="col-md-2 d-flex align-items-end"><button type="submit" class="btn-register w-100">Submit</button></div>
          </div>
        </form>
        <% if (!reviews || reviews.length === 0) { %>
          <p style="color:var(--tx-muted);font-size:0.92rem;">No reviews yet. Be the first!</p>
        <% } %>
        <% if (reviews && reviews.length > 0) { %>
          <% reviews.forEach(function(review) { %>
            <div class="review-card" data-aos="fade-up">
              <div class="review-name"><%= review.name %></div>
              <p class="review-body"><%= review.message %></p>
              <% if (isAdmin) { %>
                <form action="/events/<%= event._id %>/reviews/<%= review._id %>/delete" method="POST" class="mt-2" onsubmit="return confirm('Delete review?')">
                  <button type="submit" class="btn-admin-danger" style="padding:5px 12px;font-size:0.8rem;">✕ Delete</button>
                </form>
              <% } %>
            </div>
          <% }); %>
        <% } %>
      </div>
    <% } %>


  </div>
</div>


<style>
/* ── Page wrapper ── */
.event-detail-content { max-width:900px; margin:0 auto; }


/* ── Description body ── */
.event-description-body { font-size:clamp(0.95rem,1.5vw,1.08rem);color:var(--tx-mid);line-height:1.9;max-width:780px; }
.event-description-body p { margin-bottom:14px; }
.event-description-body ul,.event-description-body ol { padding-left:22px;margin-bottom:14px; }
.event-description-body li { margin-bottom:6px; }
.event-description-body h3,.event-description-body h4 { font-family:var(--font-display);color:var(--tx);margin:18px 0 8px;font-weight:700; }
.event-description-body strong { color:var(--tx); }
body.dark-mode .event-description-body { color:var(--dk-muted); }
body.dark-mode .event-description-body strong { color:var(--dk-text); }


/* ── Sections ── */
.detail-section { margin-bottom:38px;padding-bottom:32px;border-bottom:1px solid var(--border-l); }
.detail-section:last-child { border-bottom:none; }
.detail-section-title { font-family:var(--font-display);font-size:1.15rem;font-weight:800;color:var(--tx);margin-bottom:18px;padding-bottom:10px;border-bottom:2px solid rgba(166,124,82,0.18); }


/* ── Person / doc row ── */
.person-item { display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 16px;background:var(--cream-alt);border:1px solid var(--border-l);border-radius:var(--r-md);margin-bottom:10px;flex-wrap:wrap; }
.person-name { font-weight:700;font-size:0.95rem;color:var(--tx); }
.person-email { font-size:0.8rem;color:var(--tx-muted);margin-top:2px; }


/* ── Reviews ── */
.review-card { background:var(--cream-alt);border:1px solid var(--border-l);border-radius:var(--r-md);padding:16px 18px;margin-bottom:12px; }
.review-name { font-weight:700;font-size:0.9rem;color:var(--br);margin-bottom:6px; }
.review-body { font-size:0.9rem;color:var(--tx-mid);line-height:1.7;margin:0; }


/* ── Empty state ── */
.gallery-empty { text-align:center;padding:40px 20px;background:rgba(166,124,82,0.04);border:1.5px dashed rgba(166,124,82,0.22);border-radius:var(--r-lg);margin-bottom:20px; }
.gallery-empty-icon { font-size:2.5rem;margin-bottom:10px;opacity:0.5; }
.gallery-empty p { color:var(--tx-muted);font-size:0.92rem;margin:0; }


/* ── Generic admin form box ── */
.admin-add-form { background:rgba(166,124,82,0.04);border:1.5px dashed rgba(166,124,82,0.22);border-radius:var(--r-md);padding:18px 20px; }


body.dark-mode .person-item,
body.dark-mode .review-card { background:var(--dk-surface);border-color:var(--border-d); }
body.dark-mode .person-name { color:var(--dk-text); }
body.dark-mode .review-name { color:var(--br-light); }


/* ══════════════════════════════════════
   COMPACT SUB-EVENT CARDS (show page)
══════════════════════════════════════ */
.show-sub-card {
  background: var(--cream-alt);
  border: 1px solid var(--border-l);
  border-radius: var(--r-md);
  overflow: hidden;
  transition: border-color 0.22s, box-shadow 0.22s;
}
.show-sub-card:hover {
  border-color: var(--br);
  box-shadow: 0 4px 18px rgba(166,124,82,0.10);
}


/* Top row: title + actions side by side */
.show-sub-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  padding: clamp(12px,1.8vw,18px) clamp(14px,2vw,20px) clamp(10px,1.5vw,14px);
  flex-wrap: wrap;
}
.show-sub-left { flex: 1; min-width: 0; }
.show-sub-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(0.95rem,1.8vw,1.05rem);
  color: var(--tx);
  line-height: 1.25;
  margin-bottom: 8px;
}
.show-sub-actions {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: flex-end;
  flex-shrink: 0;
}


/* Compact pills row */
.show-sub-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}
.spill {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 3px 9px;
  border-radius: var(--r-full);
  font-size: 0.71rem;
  font-weight: 700;
  white-space: nowrap;
  border: 1px solid transparent;
}
.spill-time { background: rgba(201,168,76,0.10); border-color: rgba(201,168,76,0.26); color: #8a6914; }
.spill-type { background: rgba(166,124,82,0.08); border-color: rgba(166,124,82,0.20); color: var(--br); }
.spill-cap  { background: rgba(166,124,82,0.08); border-color: rgba(166,124,82,0.20); color: var(--br); }
.spill-pay  { background: rgba(39,174,96,0.08);  border-color: rgba(39,174,96,0.22); color: #27ae60; }
.spill-ext  { background: rgba(39,174,96,0.08);  border-color: rgba(39,174,96,0.22); color: #27ae60; }


/* Description */
.show-sub-desc {
  margin: 0 clamp(14px,2vw,20px) clamp(10px,1.5vw,14px);
  font-size: 0.83rem;
  color: var(--tx-muted);
  line-height: 1.6;
}


/* Poster — always centred, no side-float */
.show-sub-poster-wrap {
  display: flex;
  justify-content: center;
  padding: 0 clamp(14px,2vw,20px) clamp(12px,2vw,18px);
  border-top: 1px solid var(--border-l);
  padding-top: clamp(12px,2vw,16px);
}
.show-sub-poster-img {
  max-width: 320px;
  width: 100%;
  border-radius: var(--r-md);
  border: 1px solid var(--border-l);
  display: block;
}


body.dark-mode .show-sub-card { background: var(--dk-surface); border-color: var(--border-d); }
body.dark-mode .show-sub-poster-wrap { border-color: var(--border-d); }


/* ══════════════════════════════════════
   GALLERY GRID (shared by Gallery + Speakers)
══════════════════════════════════════ */
.gallery-grid-new {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}
.gallery-item-new {
  display: flex;
  flex-direction: column;
  border-radius: var(--r-md);
  overflow: hidden;
  border: 1px solid var(--border-l);
  background: var(--cream-alt);
  transition: box-shadow 0.24s ease, transform 0.24s ease;
}
.gallery-item-new:hover {
  box-shadow: 0 6px 24px rgba(166,124,82,0.14);
  transform: translateY(-2px);
}
.gallery-img-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 75%;
  overflow: hidden;
  background: rgba(166,124,82,0.06);
  flex-shrink: 0;
}
.gallery-img-actual {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.38s ease;
}
.gallery-item-new:hover .gallery-img-actual { transform: scale(1.04); }
.gal-del-btn {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: rgba(0,0,0,0.60);
  border: none; color: #fff;
  font-size: 0.65rem; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  backdrop-filter: blur(4px);
  transition: background 0.2s;
  padding: 0;
}
.gal-del-btn:hover { background: #c0392b; }
.gallery-caption-below {
  padding: 10px 13px 12px;
  border-top: 1px solid var(--border-l);
  background: var(--cream-alt);
}
.gcap-name {
  font-family: var(--font-display);
  font-size: 0.84rem; font-weight: 700;
  color: var(--tx); line-height: 1.3; margin-bottom: 2px;
}
.gcap-detail {
  font-size: 0.73rem; color: var(--tx-muted);
  line-height: 1.4; font-weight: 500;
}
body.dark-mode .gallery-item-new      { background:var(--dk-surface);border-color:var(--border-d); }
body.dark-mode .gallery-caption-below { background:var(--dk-surface);border-color:var(--border-d); }
body.dark-mode .gcap-name   { color:var(--dk-text); }
body.dark-mode .gcap-detail { color:var(--dk-muted); }

/* ── No caption: plain image only, no card border/background/hover ── */
.gallery-item-new.no-caption-card {
  background: transparent;
  border-color: transparent;
}
.gallery-item-new.no-caption-card:hover {
  box-shadow: none;
  transform: none;
  border-color: transparent;
}
.gallery-item-new.no-caption-card .gallery-img-wrap {
  border-radius: var(--r-md);
  overflow: hidden;
}
body.dark-mode .gallery-item-new.no-caption-card { background: transparent; border-color: transparent; }
@media (max-width:900px) { .gallery-grid-new { grid-template-columns:repeat(2,1fr); gap:12px; } }
@media (max-width:480px) { .gallery-grid-new { grid-template-columns:repeat(2,1fr); gap:8px; } .gcap-name{font-size:0.76rem;} .gcap-detail{font-size:0.68rem;} }


/* ── Gallery / Speaker upload form ── */
.admin-gallery-upload-form {
  background: var(--cream-alt);
  border: 1.5px dashed rgba(166,124,82,0.30);
  border-radius: var(--r-lg);
  padding: clamp(18px,2.5vw,28px);
}
.gallery-upload-fields {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 16px;
}
@media (max-width:540px) { .gallery-upload-fields { grid-template-columns:1fr; } }
.gup-label {
  display: block;
  font-size: 0.72rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1px;
  color: var(--br); margin-bottom: 6px;
}
.gup-file-area {
  border: 2px dashed rgba(166,124,82,0.32);
  border-radius: var(--r-md);
  padding: 22px 16px; text-align: center;
  cursor: pointer;
  transition: border-color 0.22s, background 0.22s;
  background: rgba(166,124,82,0.02);
}
.gup-file-area:hover { border-color: var(--br); background: rgba(166,124,82,0.05); }
.gup-file-icon  { font-size:1.8rem; margin-bottom:6px; opacity:0.55; }
.gup-file-label { font-size:0.88rem; font-weight:600; color:var(--tx-mid); margin-bottom:3px; }
.gup-file-hint  { font-size:0.75rem; color:var(--tx-muted); }
body.dark-mode .admin-gallery-upload-form { background:var(--dk-surface); }

/* ── Gallery: 4 columns on desktop, 2 on mobile ── */
.gallery-grid-new {
  grid-template-columns: repeat(4, 1fr);
}

@media (max-width: 900px) {
  .gallery-grid-new {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .gallery-grid-new {
    grid-template-columns: repeat(2, 1fr);
  }
}
/* ── Gallery caption — center aligned ── */
.gallery-caption-below {
  text-align: center;
}
</style>




<script>
function showGalleryFiles(input) {
  var el = document.getElementById('galleryFileNames');
  if (!el || !input.files.length) return;
  var names = Array.from(input.files).map(function(f){ return f.name; }).join(', ');
  el.textContent = '✓ ' + input.files.length + ' file(s) selected: ' + names;
  input.closest('.gup-file-area').style.borderColor = 'var(--br)';
}

function showSpeakerFiles(input) {
  var el = document.getElementById('speakerFileNames');
  if (!el || !input.files.length) return;
  var names = Array.from(input.files).map(function(f){ return f.name; }).join(', ');
  el.textContent = '✓ ' + input.files.length + ' file(s) selected: ' + names;
  input.closest('.gup-file-area').style.borderColor = 'var(--br)';
}
</script>
