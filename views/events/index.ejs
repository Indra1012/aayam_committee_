<!-- views/events/index.ejs -->
<div class="container">

  <div class="page-header" data-aos="fade-down">
    <div class="section-label">What's Happening</div>
    <h1 class="page-title">Events</h1>
    <p class="page-subtitle">All major events coordinated and supported by AAYAM Committee</p>
  </div>

  <!-- Mobile toggle -->
  <div class="d-lg-none" data-aos="fade-up">
    <div class="events-toggle-bar">
      <button class="evt-tab active" id="showUpcoming">Upcoming</button>
      <button class="evt-tab" id="showPast">Past Events</button>
    </div>
  </div>

  <div class="row g-4 justify-content-center">

    <!-- ── UPCOMING EVENTS ── -->
    <div class="col-lg-6" id="upcomingSection">
      <div class="d-flex align-items-center justify-content-between mb-4" data-aos="fade-up">
        <h2 class="events-col-title mb-0">Upcoming Events</h2>
      </div>

      <% if (user && (user.role === "admin" || user.role === "superadmin")) { %>
        <details class="admin-add-form mb-4" data-aos="fade-up">
          <summary style="cursor:pointer;font-weight:700;color:var(--br);list-style:none;padding:4px 0;">
            ➕ Add Upcoming Event
          </summary>
          <form action="/events/add" method="POST" enctype="multipart/form-data" class="mt-4">
            <input type="hidden" name="type" value="upcoming">
            <input type="hidden" name="isPublic" value="true">
            <input type="text" name="title" placeholder="Event Title" class="form-control mb-2" required>
            <textarea name="shortDescription" placeholder="Short description" class="form-control mb-2" required></textarea>
            <textarea name="description" placeholder="Full description" class="form-control mb-2" required></textarea>
            <textarea name="about" placeholder="About the event" class="form-control mb-2"></textarea>
            <label class="form-label fw-semibold" style="font-size:0.82rem;color:var(--br);">Start Date</label>
            <input type="date" name="startDate" class="form-control mb-2" required>
            <label class="form-label fw-semibold" style="font-size:0.82rem;color:var(--br);">End Date</label>
            <input type="date" name="endDate" class="form-control mb-2" required>
            <input type="file" name="bannerImage" class="form-control mb-2" accept="image/*" required>
            <label class="form-label fw-semibold" style="font-size:0.82rem;color:var(--br);">
              Registration Link <span style="font-weight:400;color:var(--tx-muted);">(optional)</span>
            </label>
            <input type="url" name="registrationLink" placeholder="https://forms.google.com/..." class="form-control mb-3">
            <div style="font-size:0.78rem;color:var(--tx-muted);margin-bottom:10px;padding:8px 12px;background:rgba(39,174,96,0.07);border-radius:var(--r-sm);border:1px solid rgba(39,174,96,0.18);">
              ✅ Events are <strong>Public by default</strong>. To make private, go to Edit after creating.
            </div>
            <button type="submit" class="btn-register w-100">➕ Add Upcoming Event</button>
          </form>
        </details>
      <% } %>

      <% if (!upcomingEvents || upcomingEvents.length === 0) { %>
        <div class="gallery-empty" data-aos="fade-up">
          <div class="gallery-empty-icon">📅</div>
          <p>No upcoming events right now.</p>
        </div>
      <% } %>

      <% if (upcomingEvents && upcomingEvents.length > 0) { %>
        <% upcomingEvents.forEach(function(event, i) { %>
          <div class="event-card ev-card-uniform" data-aos="fade-up" data-aos-delay="<%= i * 70 %>">

            <!-- Banner image -->
            <a href="/events/<%= event._id %>" class="ev-img-link">
              <% if (event.bannerImage) { %>
                <img
                  src="<%= event.bannerImage %>"
                  class="ev-img"
                  alt="<%= event.title %>"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                >
                <div class="ev-img-placeholder" style="display:none;"><i class="bi bi-calendar-event"></i></div>
              <% } else { %>
                <div class="ev-img-placeholder"><i class="bi bi-calendar-event"></i></div>
              <% } %>
            </a>

            <div class="ev-body">
              <!-- Title row -->
              <div class="ev-title-row">
                <a href="/events/<%= event._id %>" style="text-decoration:none;flex:1;min-width:0;">
                  <h3 class="ev-title"><%= event.title %></h3>
                </a>
                <% if (!event.isPublic && user && (user.role === "admin" || user.role === "superadmin")) { %>
                  <span class="ev-private-badge">🔒 Private</span>
                <% } %>
              </div>

              <p class="ev-desc"><%= event.shortDescription %></p>

              <% if (event.startDate && event.endDate) { %>
                <div class="ev-date">
                  <i class="bi bi-calendar3"></i>
                  <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
                    <%= new Date(event.startDate).toDateString() %>
                  <% } else { %>
                    <%= new Date(event.startDate).toDateString() %> → <%= new Date(event.endDate).toDateString() %>
                  <% } %>
                </div>
              <% } %>

              <div class="ev-actions">
                <a href="/events/<%= event._id %>" class="btn-details">View Details <i class="bi bi-arrow-right"></i></a>
                <% if (event.isPublic) { %>
                  <% if (event.registrationLink) { %>
                    <a href="<%= event.registrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-register">Register <i class="bi bi-box-arrow-up-right"></i></a>
                  <% } else { %>
                    <a href="/events/<%= event._id %>/register" class="btn-register">Register <i class="bi bi-pencil-square"></i></a>
                  <% } %>
                <% } %>
              </div>

              <% if (user && (user.role === "admin" || user.role === "superadmin")) { %>
                <div class="ev-admin-row">
                  <a href="/events/edit/<%= event._id %>" class="btn-details" style="font-size:0.75rem;padding:4px 10px;">✏ Edit</a>
                  <form action="/events/toggle-visibility/<%= event._id %>" method="POST" style="margin:0;">
                    <button type="submit" class="<%= event.isPublic ? 'btn-admin-warn' : 'btn-register' %>" style="font-size:0.75rem;padding:4px 10px;">
                      <%= event.isPublic ? '🔒 Make Private' : '🌐 Make Public' %>
                    </button>
                  </form>
                  <form action="/events/move-to-past/<%= event._id %>" method="POST" onsubmit="return confirm('Move to past?')" style="margin:0;">
                    <button type="submit" class="btn-admin-warn" style="font-size:0.75rem;padding:4px 10px;">⏳ Move to Past</button>
                  </form>
                  <form action="/events/delete/<%= event._id %>" method="POST" onsubmit="return confirm('Delete this event?')" style="margin:0;">
                    <button type="submit" class="btn-admin-danger" style="font-size:0.75rem;padding:4px 10px;">✕ Delete</button>
                  </form>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

    <!-- ── PAST EVENTS ── -->
    <div class="col-lg-6" id="pastSection">
      <div class="d-flex align-items-center justify-content-between mb-4" data-aos="fade-up">
        <h2 class="events-col-title mb-0">Past Events</h2>
      </div>

      <% if (user && (user.role === "admin" || user.role === "superadmin")) { %>
        <details class="admin-add-form mb-4" data-aos="fade-up">
          <summary style="cursor:pointer;font-weight:700;color:var(--br);list-style:none;padding:4px 0;">
            ➕ Add Past Event
          </summary>
          <form action="/events/add" method="POST" enctype="multipart/form-data" class="mt-4">
            <input type="hidden" name="type" value="past">
            <input type="hidden" name="isPublic" value="true">
            <input type="text" name="title" placeholder="Event Title" class="form-control mb-2" required>
            <textarea name="shortDescription" placeholder="Short description" class="form-control mb-2" required></textarea>
            <textarea name="description" placeholder="Full description" class="form-control mb-2" required></textarea>
            <textarea name="about" placeholder="About the event" class="form-control mb-2"></textarea>
            <label class="form-label fw-semibold" style="font-size:0.82rem;color:var(--br);">Start Date</label>
            <input type="date" name="startDate" class="form-control mb-2" required>
            <label class="form-label fw-semibold" style="font-size:0.82rem;color:var(--br);">End Date</label>
            <input type="date" name="endDate" class="form-control mb-2" required>
            <input type="file" name="bannerImage" class="form-control mb-2" accept="image/*" required>
            <input type="url" name="registrationLink" placeholder="https://..." class="form-control mb-3">
            <div style="font-size:0.78rem;color:var(--tx-muted);margin-bottom:10px;padding:8px 12px;background:rgba(39,174,96,0.07);border-radius:var(--r-sm);border:1px solid rgba(39,174,96,0.18);">
              ✅ Events are <strong>Public by default</strong>. To make private, go to Edit after creating.
            </div>
            <button type="submit" class="btn-register w-100">➕ Add Past Event</button>
          </form>
        </details>
      <% } %>

      <% if (!pastEvents || pastEvents.length === 0) { %>
        <div class="gallery-empty" data-aos="fade-up">
          <div class="gallery-empty-icon">🕰</div>
          <p>No past events yet.</p>
        </div>
      <% } %>

      <% if (pastEvents && pastEvents.length > 0) { %>
        <% pastEvents.forEach(function(event, i) { %>
          <div class="event-card ev-card-uniform" data-aos="fade-up" data-aos-delay="<%= i * 70 %>">

            <a href="/events/<%= event._id %>" class="ev-img-link">
              <% if (event.bannerImage) { %>
                <img
                  src="<%= event.bannerImage %>"
                  class="ev-img ev-img-past"
                  alt="<%= event.title %>"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                >
                <div class="ev-img-placeholder ev-img-past" style="display:none;"><i class="bi bi-calendar-check"></i></div>
              <% } else { %>
                <div class="ev-img-placeholder ev-img-past"><i class="bi bi-calendar-check"></i></div>
              <% } %>
            </a>

            <div class="ev-body">
              <div class="ev-title-row">
                <a href="/events/<%= event._id %>" style="text-decoration:none;flex:1;min-width:0;">
                  <h3 class="ev-title"><%= event.title %></h3>
                </a>
                <span class="badge-completed flex-shrink-0">Completed</span>
              </div>

              <% if (event.startDate && event.endDate) { %>
                <div class="ev-date">
                  <i class="bi bi-calendar3"></i>
                  <%= new Date(event.startDate).toDateString() %>
                  <% if (new Date(event.startDate).toDateString() !== new Date(event.endDate).toDateString()) { %>
                    → <%= new Date(event.endDate).toDateString() %>
                  <% } %>
                </div>
              <% } %>

              <div class="ev-actions">
                <a href="/events/<%= event._id %>" class="btn-details">View Details <i class="bi bi-arrow-right"></i></a>
              </div>

              <% if (user && (user.role === "admin" || user.role === "superadmin")) { %>
                <div class="ev-admin-row">
                  <a href="/events/edit/<%= event._id %>" class="btn-details" style="font-size:0.75rem;padding:4px 10px;">✏ Edit</a>
                  <form action="/events/delete/<%= event._id %>" method="POST" onsubmit="return confirm('Delete this event?')" style="margin:0;">
                    <button type="submit" class="btn-admin-danger" style="font-size:0.75rem;padding:4px 10px;">✕ Delete</button>
                  </form>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

  </div>
</div>

<style>
/* ══════════════════════════════════════
   UNIFORM EVENT CARDS — both columns
══════════════════════════════════════ */
.ev-card-uniform {
  display: flex;
  flex-direction: column;
  border-radius: var(--r-lg);
  border: 1px solid var(--border-l);
  background: var(--cream-alt);
  overflow: hidden;
  margin-bottom: 18px;
  transition: box-shadow 0.26s, transform 0.26s;
}
.ev-card-uniform:hover {
  box-shadow: 0 8px 32px rgba(166,124,82,0.12);
  transform: translateY(-2px);
}

/* Image link wrapper — padding-bottom trick for reliable ratio */
.ev-img-link {
  display: block;
  text-decoration: none;
  width: 100%;
  position: relative;
  padding-bottom: 43.75%; /* 16:7 ratio */
  overflow: hidden;
  background: rgba(166,124,82,0.06);
  flex-shrink: 0;
}

.ev-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.38s ease;
}
.ev-img-past { filter: grayscale(18%); }
.ev-card-uniform:hover .ev-img { transform: scale(1.04); }

/* Placeholder when no image */
.ev-img-placeholder {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.4rem;
  color: rgba(166,124,82,0.3);
  background: rgba(166,124,82,0.05);
}

/* Card body */
.ev-body {
  padding: clamp(14px,2vw,20px);
  display: flex;
  flex-direction: column;
  flex: 1;
}

.ev-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 6px;
}
.ev-title {
  font-family: var(--font-display);
  font-size: clamp(0.95rem, 2vw, 1.1rem);
  font-weight: 800;
  color: var(--tx);
  line-height: 1.3;
  margin: 0;
}
.ev-desc {
  font-size: 0.85rem;
  color: var(--tx-muted);
  line-height: 1.6;
  margin-bottom: 10px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.ev-date {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--tx-muted);
  margin-bottom: 12px;
}
.ev-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: auto;
  padding-top: 4px;
}
.ev-admin-row {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px dashed var(--border-l);
}

/* Admin-only private badge */
.ev-private-badge {
  padding: 2px 8px;
  border-radius: var(--r-full);
  background: rgba(192,57,43,0.09);
  border: 1px solid rgba(192,57,43,0.20);
  font-size: 0.65rem;
  font-weight: 700;
  color: #c0392b;
  white-space: nowrap;
  flex-shrink: 0;
}

body.dark-mode .ev-card-uniform { background: var(--dk-surface); border-color: var(--border-d); }

/* Responsive */
@media (max-width: 576px) {
  .ev-img-link { padding-bottom: 50%; }
  .ev-admin-row { gap: 4px; }
  .ev-actions { gap: 6px; }
}

@keyframes slideInRight { from{opacity:0;transform:translateX(40px)} to{opacity:1;transform:translateX(0)} }
@keyframes slideInLeft  { from{opacity:0;transform:translateX(-40px)} to{opacity:1;transform:translateX(0)} }
.section-animate-right { animation:slideInRight 0.4s cubic-bezier(0.25,0.46,0.45,0.94) both; }
.section-animate-left  { animation:slideInLeft  0.4s cubic-bezier(0.25,0.46,0.45,0.94) both; }
</style>

<script>
(function(){
  var showUpcomingBtn = document.getElementById('showUpcoming');
  var showPastBtn     = document.getElementById('showPast');
  var upcomingSection = document.getElementById('upcomingSection');
  var pastSection     = document.getElementById('pastSection');

  if (showUpcomingBtn && showPastBtn && window.innerWidth < 992) {
    pastSection.style.display = 'none';

    showPastBtn.addEventListener('click', function() {
      upcomingSection.style.display = 'none';
      pastSection.style.display = 'block';
      pastSection.classList.remove('section-animate-left','section-animate-right');
      void pastSection.offsetWidth;
      pastSection.classList.add('section-animate-right');
      showPastBtn.classList.add('active');
      showUpcomingBtn.classList.remove('active');
      if (typeof AOS !== 'undefined') AOS.refresh();
    });

    showUpcomingBtn.addEventListener('click', function() {
      pastSection.style.display = 'none';
      upcomingSection.style.display = 'block';
      upcomingSection.classList.remove('section-animate-left','section-animate-right');
      void upcomingSection.offsetWidth;
      upcomingSection.classList.add('section-animate-left');
      showUpcomingBtn.classList.add('active');
      showPastBtn.classList.remove('active');
    });
  }
})();
</script>
