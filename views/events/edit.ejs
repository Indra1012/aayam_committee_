/* Helper: generate time <option> list 12h AM/PM every 30 min */
function generateTimeOptions(selected) {
  var out = '';
  var slots = [];
  for (var h = 0; h < 24; h++) {
    for (var m = 0; m < 60; m += 30) {
      var suffix = h < 12 ? 'AM' : 'PM';
      var h12    = h === 0 ? 12 : h > 12 ? h - 12 : h;
      var label  = (h12 < 10 ? '0' : '') + h12 + ':' + (m === 0 ? '00' : '30') + ' ' + suffix;
      slots.push(label);
    }
  }
  slots.forEach(function(s) {
    var sel = (s === selected) ? ' selected' : '';
    out += '<option value="' + s + '"' + sel + '>' + s + '</option>';
  });
  return out;
}
%>
